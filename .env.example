# ──────────────────────────────────────────────────────────────────────────────
# Central operator & site configuration
# Copy this file to .env.local and fill in the values before running locally.
# In production (Vercel) set these as environment variables in the dashboard.
# ──────────────────────────────────────────────────────────────────────────────

# Full legal name of the site operator (required for Impressum / Datenschutz)
# ⚠️  MUST be filled in before going live – no placeholder may appear on the site
OPERATOR_NAME=Mario Reiner

# Public contact e-mail address shown in Impressum, Datenschutz, and footer
OPERATOR_EMAIL=kontakt@flussdeslebens.live

# Contact phone number in E.164 format
OPERATOR_PHONE_E164=+6283832835228

# Naked domain (without protocol) used for canonical links and e-mail headers
SITE_DOMAIN=flussdeslebens.live

# E-mail address that identifies / seeds the single admin account
ADMIN_SEED_EMAIL=kontakt@flussdeslebens.live

# PayPal account e-mail used for the donation button
# Defaults to marioreinerdenzer@gmail.com if omitted
PAYPAL_BUSINESS_EMAIL=marioreinerdenzer@gmail.com

# ──────────────────────────────────────────────────────────────────────────────
# NextAuth
# ──────────────────────────────────────────────────────────────────────────────

# Base URL used by NextAuth on the environment where the app is currently running.
# For local development use your local origin, e.g. http://localhost:3000
# In production set this to the live public URL (no trailing slash).
NEXTAUTH_URL=http://localhost:3000

# Random secret used to sign session tokens – generate with: openssl rand -base64 32
NEXTAUTH_SECRET=REPLACE_WITH_RANDOM_SECRET

# ──────────────────────────────────────────────────────────────────────────────
# Transactional e-mail via Resend (https://resend.com)
#
# How to obtain the API key:
#   1. Log in at https://resend.com
#   2. Go to API Keys → Create API Key
#   3. Copy the generated key into RESEND_API_KEY below
#
# Domain verification (required before going live):
#   1. In your Resend dashboard go to Domains → Add Domain
#   2. Enter the domain used in EMAIL_FROM (e.g. flussdeslebens.live)
#   3. Add the displayed DNS records (MX, TXT, DKIM) to your DNS provider
#   4. Wait for Resend to show the domain as "Verified"
#   Without a verified domain every outgoing e-mail will be rejected by Resend.
# ──────────────────────────────────────────────────────────────────────────────

# Resend API key (required) – get it at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxx

# Sender address – MUST use a domain that is verified in your Resend account.
# Used as the From: address in all outgoing mails.
EMAIL_FROM=kontakt@flussdeslebens.live

# Shared secret for the scheduled weekly faith email endpoint.
# Use the same value in GitHub Actions as WEEKLY_FAITH_EMAIL_CRON_SECRET.
WEEKLY_FAITH_EMAIL_CRON_SECRET=REPLACE_WITH_RANDOM_SECRET

# Optional: force JSON persistence through the GitHub API outside Vercel.
# Leave unset for local development so app data is written to the local data/*.json files.
# ENABLE_GITHUB_DATA_SYNC=false
