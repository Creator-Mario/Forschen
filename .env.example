# ──────────────────────────────────────────────────────────────────────────────
# Central operator & site configuration
# Copy this file to .env.local and fill in the values before running locally.
# In production (Vercel) set these as environment variables in the dashboard.
# ──────────────────────────────────────────────────────────────────────────────

# Full legal name of the site operator (required for Impressum / Datenschutz)
# ⚠️  MUST be filled in before going live – no placeholder may appear on the site
OPERATOR_NAME=HIER_DEN_ECHTEN_BETREIBERNAMEN_EINTRAGEN_VOR_DEPLOY

# Public contact e-mail address shown in Impressum, Datenschutz, and footer
OPERATOR_EMAIL=kontakt@flussdeslebens.live

# Contact phone number in E.164 format
OPERATOR_PHONE_E164=+6283832835228

# Naked domain (without protocol) used for canonical links and e-mail headers
SITE_DOMAIN=flussdeslebens.live

# E-mail address that identifies / seeds the single admin account
ADMIN_SEED_EMAIL=kontakt@flussdeslebens.live

# PayPal account e-mail used for the donation button
# Defaults to marioreinerdenzer@gmail.com if omitted
PAYPAL_BUSINESS_EMAIL=marioreinerdenzer@gmail.com

# ──────────────────────────────────────────────────────────────────────────────
# NextAuth
# ──────────────────────────────────────────────────────────────────────────────

# Full public URL of the deployment (no trailing slash)
NEXTAUTH_URL=https://www.flussdeslebens.live

# Random secret used to sign session tokens – generate with: openssl rand -base64 32
NEXTAUTH_SECRET=REPLACE_WITH_RANDOM_SECRET

# ──────────────────────────────────────────────────────────────────────────────
# Transactional e-mail via Brevo (smtp-relay.brevo.com)
#
# How to find these values in your Brevo account:
#   1. Log in at https://app.brevo.com
#   2. Go to  Settings → SMTP & API → SMTP
#   3. Copy "Login" (= EMAIL_SERVER_USER) and generate / copy "Password" (= EMAIL_SERVER_PASSWORD)
#
# Brevo SMTP host and port are fixed – do not change them.
#
# Variable names follow the NextAuth.js / Vercel convention (EMAIL_SERVER_*).
# The legacy SMTP_* names are still accepted as fallbacks for local development.
# ──────────────────────────────────────────────────────────────────────────────

# Primary names (must be set in Vercel / production)
EMAIL_SERVER_HOST=smtp-relay.brevo.com
EMAIL_SERVER_PORT=587
EMAIL_SERVER_USER=REPLACE_WITH_BREVO_SMTP_LOGIN
EMAIL_SERVER_PASSWORD=REPLACE_WITH_BREVO_SMTP_PASSWORD

# Sender address – must be a verified domain or sender in Brevo
# Used as the From: address in all outgoing mails.
EMAIL_FROM=noreply@flussdeslebens.live

# ── Legacy aliases (kept for .env.local backward-compatibility only) ──────────
# These are still read as fallbacks when the EMAIL_SERVER_* vars are absent.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=REPLACE_WITH_BREVO_SMTP_LOGIN
SMTP_PASS=REPLACE_WITH_BREVO_SMTP_PASSWORD

# Sender name shown in e-mail clients
MAIL_FROM_NAME=Der Fluss des Lebens

# Sender address (legacy fallback – prefer EMAIL_FROM above)
MAIL_FROM_ADDRESS=noreply@flussdeslebens.live

# Reply-To address for all outgoing mails
MAIL_REPLY_TO=kontakt@flussdeslebens.live

