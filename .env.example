# ──────────────────────────────────────────────────────────────────────────────
# Central operator & site configuration
# Copy this file to .env.local and fill in the values before running locally.
# In production (Vercel) set these as environment variables in the dashboard.
# ──────────────────────────────────────────────────────────────────────────────

# Full legal name of the site operator (required for Impressum / Datenschutz)
# ⚠️  MUST be filled in before going live – no placeholder may appear on the site
OPERATOR_NAME=HIER_DEN_ECHTEN_BETREIBERNAMEN_EINTRAGEN_VOR_DEPLOY

# Public contact e-mail address shown in Impressum, Datenschutz, and footer
OPERATOR_EMAIL=kontakt@flussdeslebens.live

# Contact phone number in E.164 format
OPERATOR_PHONE_E164=+6283832835228

# Naked domain (without protocol) used for canonical links and e-mail headers
SITE_DOMAIN=flussdeslebens.live

# E-mail address that identifies / seeds the single admin account
ADMIN_SEED_EMAIL=kontakt@flussdeslebens.live

# PayPal account e-mail used for the donation button (defaults to OPERATOR_EMAIL if omitted)
PAYPAL_BUSINESS_EMAIL=

# ──────────────────────────────────────────────────────────────────────────────
# SMTP (for transactional e-mails – registration confirmation etc.)
# ──────────────────────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
